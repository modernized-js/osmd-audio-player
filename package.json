{
  "name": "osmd-audio-player",
  "version": "0.7.0",
  "description": "OSMD audio player",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsc -w",
    "test": "vitest run",
    "prepare": "yarn build",
    "build": "tsc -p tsconfig.build.json",
    "build-umd": "rollup -c rollup.umd.config.js",
    "install-demo:vue": "yarn --cwd demos/vue-player-demo install",
    "install-demo:basic": "yarn --cwd demos/basic install",
    "install-demos": "run-p install-demo:*",
    "build-demo:vue": "yarn --cwd demos/vue-player-demo build",
    "build-demo:basic": "yarn --cwd demos/basic build",
    "build-demos": "run-p build-demo:*",
    "build-all": "run-s build build-umd build-demos",
    "netlify-build": "run-s build install-demos build-demos"
  },
  "author": "Jimmy Utterström",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jimutt/osmd-audio-player"
  },
  "keywords": [
    "MusicXML",
    "Music XML",
    "audio player",
    "MusicXML audio",
    "music notation"
  ],
  "dependencies": {
    "opensheetmusicdisplay": "^0.8.4",
    "soundfont-player": "^0.12.0",
    "standardized-audio-context": "^24.1.25"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "jsdom": "^29.0.1",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.60.1",
    "ts-mockito": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
